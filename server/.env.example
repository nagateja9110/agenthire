# Note: on macOS, port 5000 is often taken by AirPlay Receiver - use 5001
PORT=5001
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/agenthire

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Primary LLM (free tier: https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback LLM (free models: https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Email (free tier: https://resend.com). Leave empty to use fallback output.
RESEND_API_KEY=

# Murf AI text-to-speech (https://murf.ai) - leave empty to use browser TTS
MURF_API_KEY=
MURF_VOICE_ID=Anisha

# AssemblyAI speech-to-text (https://www.assemblyai.com) - leave empty to use browser STT
ASSEMBLYAI_API_KEY=

CLIENT_URL=http://localhost:3000
